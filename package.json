{
  "name": "@cronlabs/core",
  "version": "0.0.0",
  "description": "The CronLabs cron engine: parse, validate, explain, compute next runs, and detect scheduling edge cases (DST, phantom schedules). Pure TypeScript, no I/O.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json"
  },
  "keywords": [
    "cron",
    "crontab",
    "scheduler",
    "dst",
    "timezone",
    "validation"
  ],
  "dependencies": {
    "croner": "^9.1.0"
  },
  "devDependencies": {
    "typescript": "^5",
    "vitest": "^3"
  }
}
