{
  "name": "@cronlabs/core",
  "version": "0.1.0",
  "description": "The CronLabs cron engine: parse, validate, explain, compute next runs, detect scheduling edge cases (DST, phantom schedules), and convert between platform cron dialects. Pure TypeScript, no I/O.",
  "license": "MIT",
  "author": "CronLabs",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cron",
    "crontab",
    "scheduler",
    "cron-parser",
    "cron-validator",
    "cron-converter",
    "dst",
    "timezone"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Acy1999/cronlabs-core.git"
  },
  "homepage": "https://github.com/Acy1999/cronlabs-core#readme",
  "bugs": {
    "url": "https://github.com/Acy1999/cronlabs-core/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "croner": "^9.1.0"
  },
  "devDependencies": {
    "typescript": "^5",
    "vitest": "^3"
  }
}
